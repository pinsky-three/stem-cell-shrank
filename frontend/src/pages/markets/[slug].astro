---
import Base from "../../layouts/Base.astro";

export function getStaticPaths() {
  return [
    { params: { slug: "ganador-eliminatorias-2026" } },
    { params: { slug: "proximo-presidente" } },
    { params: { slug: "liga1-2025" } },
    { params: { slug: "dolar-diciembre" } },
    { params: { slug: "miss-universo-2025" } },
    { params: { slug: "btc-navidad" } },
  ];
}

const { slug } = Astro.params;

const marketData: Record<string, { title: string; description: string; category: string; expiry: string; volume: string; traders: string; outcomes: { name: string; price: number; color: string }[] }> = {
  "ganador-eliminatorias-2026": {
    title: "¿Perú clasificará al Mundial 2026?",
    description: "Apuesta sobre si la selección peruana de fútbol clasificará a la Copa Mundo FIFA 2026 que se realizará en Estados Unidos, México y Canadá.",
    category: "Política",
    expiry: "15 días",
    volume: "S/ 45,230",
    traders: "1,247",
    outcomes: [
      { name: "Sí", price: 0.72, color: "green" },
      { name: "No", price: 0.28, color: "red" }
    ]
  },
  "proximo-presidente": {
    title: "¿Quién será presidente 2026-2030?",
    description: "Predice quién ganará las elecciones presidenciales del Perú en 2026. El mercado se resolve cuando se anuncie el ganador oficial.",
    category: "Política",
    expiry: "89 días",
    volume: "S/ 128,450",
    traders: "3,891",
    outcomes: [
      { name: "Margarita Pando", price: 0.35, color: "green" },
      { name: "Rafael López", price: 0.28, color: "neutral" },
      { name: "Otro", price: 0.37, color: "neutral" }
    ]
  },
  "liga1-2025": {
    title: "¿Universitario gana la Liga 1 2025?",
    description: "Apuesta sobre si el Club Universidad de San Martín de Porres ganará el Torneo Clausura o la Liga 1 2025.",
    category: "Deportes",
    expiry: "120 días",
    volume: "S/ 89,120",
    traders: "2,104",
    outcomes: [
      { name: "Sí", price: 0.62, color: "green" },
      { name: "No", price: 0.38, color: "red" }
    ]
  },
  "dolar-diciembre": {
    title: "¿El dólar supera S/ 4.00 en diciembre?",
    description: "Predice si el tipo de cambio del dólar estadounidense superará los S/ 4.00 soles peruanos antes del 31 de diciembre de 2025.",
    category: "Economía",
    expiry: "45 días",
    volume: "S/ 67,890",
    traders: "1,567",
    outcomes: [
      { name: "Sí", price: 0.45, color: "green" },
      { name: "No", price: 0.55, color: "red" }
    ]
  },
  "miss-universo-2025": {
    title: "¿Perú queda top 5 en Miss Universo 2025?",
    description: "Apuesta sobre si la candidata peruana quedará entre las 5 primeras en el concurso Miss Universo 2025.",
    category: "Entretenimiento",
    expiry: "60 días",
    volume: "S/ 23,450",
    traders: "892",
    outcomes: [
      { name: "Sí", price: 0.28, color: "green" },
      { name: "No", price: 0.72, color: "red" }
    ]
  },
  "btc-navidad": {
    title: "¿BTC supera $100k antes de Navidad?",
    description: "Predice si el precio de Bitcoin superará los $100,000 dólares estadounidenses antes del 25 de diciembre de 2025.",
    category: "Crypto",
    expiry: "30 días",
    volume: "S/ 156,780",
    traders: "4,231",
    outcomes: [
      { name: "Sí", price: 0.58, color: "green" },
      { name: "No", price: 0.42, color: "red" }
    ]
  }
};

const market = marketData[slug!];

---

<Base title={market.title} description={market.description}>
  <main class="min-h-[calc(100vh-4rem)] bg-neutral-950">
    <div class="mx-auto max-w-7xl px-6 py-8">
      <!-- Breadcrumb -->
      <nav class="mb-6 flex items-center gap-2 text-sm text-neutral-500">
        <a href="/" class="hover:text-white">Inicio</a>
        <span>/</span>
        <span class="text-white">{market.category}</span>
        <span>/</span>
        <span class="text-neutral-400">Detalle</span>
      </nav>

      <div class="grid gap-8 lg:grid-cols-3">
        <!-- Main Content -->
        <div class="lg:col-span-2 space-y-6">
          <!-- Market Header -->
          <div class="rounded-2xl border border-neutral-800 bg-neutral-900 p-6">
            <div class="mb-4 flex items-center gap-3">
              <span class="rounded-full bg-red-600/20 px-3 py-1 text-xs font-medium text-red-400">{market.category}</span>
              <span class="text-sm text-neutral-500">Expira en {market.expiry}</span>
            </div>
            <h1 class="text-2xl font-bold text-white md:text-3xl">{market.title}</h1>
            <p class="mt-3 text-neutral-400">{market.description}</p>
          </div>

          <!-- Price Chart Area -->
          <div class="rounded-2xl border border-neutral-800 bg-neutral-900 p-6">
            <div class="mb-4 flex items-center justify-between">
              <h2 class="text-lg font-semibold text-white">Historial de Precios</h2>
              <div class="flex gap-2">
                <button class="rounded-lg bg-neutral-800 px-3 py-1 text-xs text-neutral-400 hover:bg-neutral-700">1H</button>
                <button class="rounded-lg bg-neutral-800 px-3 py-1 text-xs text-neutral-400 hover:bg-neutral-700">24H</button>
                <button class="rounded-lg bg-red-600 px-3 py-1 text-xs text-white">7D</button>
              </div>
            </div>
            <div class="flex h-48 items-end justify-between gap-2 border-b border-l border-neutral-700 pl-4">
              <div class="flex h-full items-end">
                <div class="w-8 rounded-t bg-green-600/50" style="height: 65%"></div>
              </div>
              <div class="flex h-full items-end">
                <div class="w-8 rounded-t bg-green-600/50" style="height: 68%"></div>
              </div>
              <div class="flex h-full items-end">
                <div class="w-8 rounded-t bg-green-600/50" style="height: 62%"></div>
              </div>
              <div class="flex h-full items-end">
                <div class="w-8 rounded-t bg-green-600/50" style="height: 70%"></div>
              </div>
              <div class="flex h-full items-end">
                <div class="w-8 rounded-t bg-green-600/50" style="height: 72%"></div>
              </div>
              <div class="flex h-full items-end">
                <div class="w-8 rounded-t bg-green-600" style="height: 75%"></div>
              </div>
              <div class="flex h-full items-end">
                <div class="w-8 rounded-t bg-green-600" style="height: 72%"></div>
              </div>
            </div>
            <div class="mt-4 flex items-center justify-between text-xs text-neutral-500">
              <span>Hace 7 días</span>
              <span>72¢ (-3.2%)</span>
              <span>Ahora</span>
            </div>
          </div>

          <!-- Order Book -->
          <div class="rounded-2xl border border-neutral-800 bg-neutral-900 p-6">
            <h2 class="mb-4 text-lg font-semibold text-white">Libro de Órdenes</h2>
            <div class="space-y-3">
              <div class="flex items-center justify-between py-2 border-b border-neutral-800">
                <div class="flex items-center gap-4">
                  <span class="text-green-400">72¢</span>
                  <div class="h-1 w-32 rounded-full bg-neutral-700">
                    <div class="h-1 w-24 rounded-full bg-green-500"></div>
                  </div>
                </div>
                <div class="text-sm text-neutral-400">S/ 12,450</div>
              </div>
              <div class="flex items-center justify-between py-2 border-b border-neutral-800">
                <div class="flex items-center gap-4">
                  <span class="text-green-400">71¢</span>
                  <div class="h-1 w-32 rounded-full bg-neutral-700">
                    <div class="h-1 w-16 rounded-full bg-green-500"></div>
                  </div>
                </div>
                <div class="text-sm text-neutral-400">S/ 8,230</div>
              </div>
              <div class="flex items-center justify-between py-2 border-b border-neutral-800">
                <div class="flex items-center gap-4">
                  <span class="text-neutral-400">70¢</span>
                  <div class="h-1 w-32 rounded-full bg-neutral-700">
                    <div class="h-1 w-20 rounded-full bg-neutral-500"></div>
                  </div>
                </div>
                <div class="text-sm text-neutral-400">S/ 15,670</div>
              </div>
              <div class="flex items-center justify-between py-2 border-b border-neutral-800">
                <div class="flex items-center gap-4">
                  <span class="text-red-400">28¢</span>
                  <div class="h-1 w-32 rounded-full bg-neutral-700">
                    <div class="h-1 w-18 rounded-full bg-red-500"></div>
                  </div>
                </div>
                <div class="text-sm text-neutral-400">S/ 9,890</div>
              </div>
              <div class="flex items-center justify-between py-2">
                <div class="flex items-center gap-4">
                  <span class="text-red-400">27¢</span>
                  <div class="h-1 w-32 rounded-full bg-neutral-700">
                    <div class="h-1 w-12 rounded-full bg-red-500"></div>
                  </div>
                </div>
                <div class="text-sm text-neutral-400">S/ 5,340</div>
              </div>
            </div>
          </div>
        </div>

        <!-- Trading Sidebar -->
        <div class="space-y-6">
          <!-- Outcome Selection -->
          <div class="sticky top-24 rounded-2xl border border-neutral-800 bg-neutral-900 p-6">
            <h2 class="mb-4 text-lg font-semibold text-white">Apostar</h2>
            
            <div class="mb-6 space-y-3">
              {market.outcomes.map((outcome, index) => (
                <label class={`flex cursor-pointer items-center justify-between rounded-xl border p-4 transition ${index === 0 ? 'border-green-500 bg-green-500/10' : 'border-neutral-700 hover:border-neutral-600'}`}>
                  <div class="flex items-center gap-3">
                    <input type="radio" name="outcome" value={outcome.name} class="sr-only" checked={index === 0} />
                    <div class={`h-4 w-4 rounded-full border-2 ${index === 0 ? 'border-green-500 bg-green-500' : 'border-neutral-600'}`}></div>
                    <span class="font-medium text-white">{outcome.name}</span>
                  </div>
                  <span class={`font-mono font-bold ${outcome.color === 'green' ? 'text-green-400' : outcome.color === 'red' ? 'text-red-400' : 'text-neutral-400'}`}>
                    {Math.round(outcome.price * 100)}¢
                  </span>
                </label>
              ))}
            </div>

            <!-- Amount Input -->
            <div class="mb-6">
              <label class="mb-2 block text-sm text-neutral-400">Cantidad a apostar</label>
              <div class="relative">
                <span class="absolute left-4 top-1/2 -translate-y-1/2 text-neutral-500">S/</span>
                <input type="number" value="50" min="1" class="w-full rounded-xl border border-neutral-700 bg-neutral-800 py-3 pl-10 pr-4 text-white placeholder-neutral-500 focus:border-red-500 focus:outline-none" />
              </div>
            </div>

            <!-- Potential Returns -->
            <div class="mb-6 space-y-3 rounded-xl bg-neutral-800/50 p-4">
              <div class="flex justify-between text-sm">
                <span class="text-neutral-400">Probabilidad</span>
                <span class="font-medium text-white">72%</span>
              </div>
              <div class="flex justify-between text-sm">
                <span class="text-neutral-400">Ganancia potencial</span>
                <span class="font-medium text-green-400">+S/ 19.44</span>
              </div>
              <div class="flex justify-between text-sm">
                <span class="text-neutral-400">Retorno</span>
                <span class="font-medium text-white">+38.9%</span>
              </div>
            </div>

            <!-- Action Buttons -->
            <div class="space-y-3">
              <button class="w-full rounded-xl bg-green-600 py-3 font-semibold text-white transition hover:bg-green-500">
                Comprar Sí
              </button>
              <button class="w-full rounded-xl bg-red-600 py-3 font-semibold text-white transition hover:bg-red-500">
                Comprar No
              </button>
            </div>

            <!-- Market Stats -->
            <div class="mt-6 border-t border-neutral-800 pt-6">
              <div class="grid grid-cols-2 gap-4 text-center">
                <div>
                  <p class="text-xs text-neutral-500">Volumen</p>
                  <p class="font-mono font-semibold text-white">{market.volume}</p>
                </div>
                <div>
                  <p class="text-xs text-neutral-500">Apostadores</p>
                  <p class="font-mono font-semibold text-white">{market.traders}</p>
                </div>
              </div>
            </div>

            <!-- Resolve Info -->
            <div class="mt-4 rounded-lg bg-neutral-800/30 p-3">
              <p class="text-xs text-neutral-500">
                <span class="font-medium text-neutral-400">Resolución:</span> Este mercado se resolverá 24 horas después del evento. Consulta las reglas completas para más detalles.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
</Base>
