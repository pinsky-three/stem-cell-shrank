<!-- @generated from specs/self.yaml — do not edit -->
---
import Base from "../layouts/Base.astro";
---
<Base title="Task | Admin" noindex={true}>
  <div class="mx-auto max-w-7xl px-6 py-12">
    <div class="flex items-center justify-between">
      <div class="flex items-center gap-4">
        <a href="/" class="text-neutral-500 transition hover:text-neutral-300">&larr; Dashboard</a>
        <h1 class="text-3xl font-bold tracking-tight">Task</h1>
      </div>
      <button id="create-btn" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold transition hover:bg-indigo-500">
        + New task
      </button>
    </div>

    <!-- Data table -->
    <div class="mt-8 overflow-x-auto rounded-xl border border-neutral-800">
      <table class="w-full">
        <thead class="border-b border-neutral-800 bg-neutral-900/50">
          <tr>
          <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-neutral-400">id</th>
          <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-neutral-400">title</th>
          <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-neutral-400">description</th>
          <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-neutral-400">priority</th>
          <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-neutral-400">sort_order</th>
          <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-neutral-400">done</th>
          <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-neutral-400">estimated_hours</th>
          <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-neutral-400">actual_hours</th>
          <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-neutral-400">project_id</th>
          <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-neutral-400">sprint_id</th>
          <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-neutral-400">milestone_id</th>
          <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-neutral-400">assignee_id</th>
          <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-neutral-400">reporter_id</th>
          <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-neutral-400">category_id</th>
          <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-neutral-400">actions</th>
          </tr>
        </thead>
        <tbody id="table-body" class="divide-y divide-neutral-800/50"></tbody>
      </table>
    </div>
  </div>

  <!-- Form dialog -->
  <dialog id="form-dialog" class="rounded-xl border border-neutral-700 bg-neutral-900 p-0 text-neutral-100 shadow-2xl backdrop:bg-black/60">
    <form id="entity-form" method="dialog" class="flex flex-col gap-4 p-6" style="min-width:380px">
      <h2 id="form-title" class="text-lg font-bold">New task</h2>
      <div class="flex flex-col gap-3">
        <input type="text" name="title" placeholder="title"
              class="rounded-lg border border-neutral-700 bg-neutral-800 px-3 py-2 text-sm text-neutral-100 placeholder:text-neutral-500 focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" required />
        <textarea name="description" placeholder="description" rows="2"
              class="rounded-lg border border-neutral-700 bg-neutral-800 px-3 py-2 text-sm text-neutral-100 placeholder:text-neutral-500 focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500"></textarea>
        <input type="number" name="priority" placeholder="priority" step="1"
              class="rounded-lg border border-neutral-700 bg-neutral-800 px-3 py-2 text-sm text-neutral-100 placeholder:text-neutral-500 focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" required />
        <input type="number" name="sort_order" placeholder="sort_order" step="1"
              class="rounded-lg border border-neutral-700 bg-neutral-800 px-3 py-2 text-sm text-neutral-100 placeholder:text-neutral-500 focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" required />
        <label class="flex items-center gap-2 text-sm">
              <input type="checkbox" name="done" class="rounded border-neutral-600 bg-neutral-800 text-indigo-500 focus:ring-indigo-500" />
              done
            </label>
        <input type="number" name="estimated_hours" placeholder="estimated_hours" step="any"
              class="rounded-lg border border-neutral-700 bg-neutral-800 px-3 py-2 text-sm text-neutral-100 placeholder:text-neutral-500 focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" />
        <input type="number" name="actual_hours" placeholder="actual_hours" step="any"
              class="rounded-lg border border-neutral-700 bg-neutral-800 px-3 py-2 text-sm text-neutral-100 placeholder:text-neutral-500 focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" />
        <input type="text" name="project_id" placeholder="project_id (UUID)"
              pattern="[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}"
              class="rounded-lg border border-neutral-700 bg-neutral-800 px-3 py-2 text-sm text-neutral-100 placeholder:text-neutral-500 focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" required />
        <input type="text" name="sprint_id" placeholder="sprint_id (UUID)"
              pattern="[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}"
              class="rounded-lg border border-neutral-700 bg-neutral-800 px-3 py-2 text-sm text-neutral-100 placeholder:text-neutral-500 focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" />
        <input type="text" name="milestone_id" placeholder="milestone_id (UUID)"
              pattern="[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}"
              class="rounded-lg border border-neutral-700 bg-neutral-800 px-3 py-2 text-sm text-neutral-100 placeholder:text-neutral-500 focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" />
        <input type="text" name="assignee_id" placeholder="assignee_id (UUID)"
              pattern="[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}"
              class="rounded-lg border border-neutral-700 bg-neutral-800 px-3 py-2 text-sm text-neutral-100 placeholder:text-neutral-500 focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" required />
        <input type="text" name="reporter_id" placeholder="reporter_id (UUID)"
              pattern="[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}"
              class="rounded-lg border border-neutral-700 bg-neutral-800 px-3 py-2 text-sm text-neutral-100 placeholder:text-neutral-500 focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" required />
        <input type="text" name="category_id" placeholder="category_id (UUID)"
              pattern="[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}"
              class="rounded-lg border border-neutral-700 bg-neutral-800 px-3 py-2 text-sm text-neutral-100 placeholder:text-neutral-500 focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" />
      </div>
      <div class="flex justify-end gap-3 pt-2">
        <button type="button" id="cancel-btn" class="rounded-lg border border-neutral-700 px-4 py-2 text-sm transition hover:bg-neutral-800">Cancel</button>
        <button type="submit" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold transition hover:bg-indigo-500">Save</button>
      </div>
    </form>
  </dialog>

  <!-- Relation panel -->
  <dialog id="rel-dialog" class="rounded-xl border border-neutral-700 bg-neutral-900 p-6 text-neutral-100 shadow-2xl backdrop:bg-black/60" style="min-width:400px;max-height:80vh">
    <div class="flex items-center justify-between mb-4">
      <h2 id="rel-title" class="text-lg font-bold"></h2>
      <button onclick="document.getElementById('rel-dialog').close()" class="text-neutral-500 hover:text-neutral-300">&times;</button>
    </div>
    <pre id="rel-body" class="overflow-auto text-xs text-neutral-300 bg-neutral-800 rounded-lg p-4 max-h-96"></pre>
  </dialog>

  <script>
    const API = '/api/tasks';
    const dialog = document.getElementById('form-dialog');
    const form = document.getElementById('entity-form');
    const relDialog = document.getElementById('rel-dialog');
    let editingId = null;

    function renderRow(r) {
      return `<tr class="transition hover:bg-neutral-900/30">` +
        `<td class="px-4 py-3 font-mono text-xs text-neutral-500">${r.id.substring(0,8)}...</td>`+
        `<td class="px-4 py-3 text-sm text-neutral-300">${r.title??'—'}</td>`+
        `<td class="px-4 py-3 text-sm text-neutral-300">${r.description??'—'}</td>`+
        `<td class="px-4 py-3 text-sm text-neutral-300">${r.priority??'—'}</td>`+
        `<td class="px-4 py-3 text-sm text-neutral-300">${r.sort_order??'—'}</td>`+
        `<td class="px-4 py-3 text-sm">${r.done?'<span class="text-green-400">yes</span>':'<span class="text-red-400">no</span>'}</td>`+
        `<td class="px-4 py-3 text-sm text-neutral-300">${r.estimated_hours??'—'}</td>`+
        `<td class="px-4 py-3 text-sm text-neutral-300">${r.actual_hours??'—'}</td>`+
        `<td class="px-4 py-3 font-mono text-xs"><a href="/projects" class="text-indigo-400 hover:underline">${r.project_id?r.project_id.substring(0,8)+'...':'—'}</a></td>`+
        `<td class="px-4 py-3 font-mono text-xs"><a href="/sprints" class="text-indigo-400 hover:underline">${r.sprint_id?r.sprint_id.substring(0,8)+'...':'—'}</a></td>`+
        `<td class="px-4 py-3 font-mono text-xs"><a href="/milestones" class="text-indigo-400 hover:underline">${r.milestone_id?r.milestone_id.substring(0,8)+'...':'—'}</a></td>`+
        `<td class="px-4 py-3 font-mono text-xs"><a href="/users" class="text-indigo-400 hover:underline">${r.assignee_id?r.assignee_id.substring(0,8)+'...':'—'}</a></td>`+
        `<td class="px-4 py-3 font-mono text-xs"><a href="/users" class="text-indigo-400 hover:underline">${r.reporter_id?r.reporter_id.substring(0,8)+'...':'—'}</a></td>`+
        `<td class="px-4 py-3 font-mono text-xs"><a href="/categories" class="text-indigo-400 hover:underline">${r.category_id?r.category_id.substring(0,8)+'...':'—'}</a></td>` +
        `<td class="px-4 py-3 text-sm flex gap-3">
          <button onclick="editItem('${r.id}')" class="text-indigo-400 hover:underline">edit</button>
          <button onclick="deleteItem('${r.id}')" class="text-red-400 hover:underline">del</button>
          <button onclick="showRelation('${r.id}','comments')" class="text-indigo-400 hover:underline">comments</button> <button onclick="showRelation('${r.id}','time_entries')" class="text-indigo-400 hover:underline">time_entries</button> <button onclick="showRelation('${r.id}','line_items')" class="text-indigo-400 hover:underline">line_items</button>
        </td></tr>`;
    }

    async function loadData() {
      const res = await fetch(API);
      const items = await res.json();
      document.getElementById('table-body').innerHTML = items.map(renderRow).join('');
    }

    document.getElementById('create-btn').addEventListener('click', () => {
      editingId = null;
      form.reset();
      document.getElementById('form-title').textContent = 'New task';
      dialog.showModal();
    });

    document.getElementById('cancel-btn').addEventListener('click', () => dialog.close());

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const body = {
        title: form.elements['title'].value,
        description: form.elements['description'].value || null,
        priority: form.elements['priority'].value ? Number(form.elements['priority'].value) : null,
        sort_order: form.elements['sort_order'].value ? Number(form.elements['sort_order'].value) : null,
        done: form.elements['done'].checked,
        estimated_hours: form.elements['estimated_hours'].value ? parseFloat(form.elements['estimated_hours'].value) : null,
        actual_hours: form.elements['actual_hours'].value ? parseFloat(form.elements['actual_hours'].value) : null,
        project_id: form.elements['project_id'].value,
        sprint_id: form.elements['sprint_id'].value || null,
        milestone_id: form.elements['milestone_id'].value || null,
        assignee_id: form.elements['assignee_id'].value,
        reporter_id: form.elements['reporter_id'].value,
        category_id: form.elements['category_id'].value || null
      };
      const url = editingId ? `${API}/${editingId}` : API;
      const method = editingId ? 'PUT' : 'POST';
      await fetch(url, {
        method,
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
      dialog.close();
      loadData();
    });

    window.editItem = async function(id) {
      const res = await fetch(`${API}/${id}`);
      const item = await res.json();
      editingId = id;
      document.getElementById('form-title').textContent = 'Edit task';
      form.elements['title'].value = item.title ?? '';
      form.elements['description'].value = item.description ?? '';
      form.elements['priority'].value = item.priority ?? '';
      form.elements['sort_order'].value = item.sort_order ?? '';
      form.elements['done'].checked = item.done;
      form.elements['estimated_hours'].value = item.estimated_hours ?? '';
      form.elements['actual_hours'].value = item.actual_hours ?? '';
      form.elements['project_id'].value = item.project_id ?? '';
      form.elements['sprint_id'].value = item.sprint_id ?? '';
      form.elements['milestone_id'].value = item.milestone_id ?? '';
      form.elements['assignee_id'].value = item.assignee_id ?? '';
      form.elements['reporter_id'].value = item.reporter_id ?? '';
      form.elements['category_id'].value = item.category_id ?? '';
      dialog.showModal();
    };

    window.deleteItem = async function(id) {
      if (!confirm('Delete this task?')) return;
      await fetch(`${API}/${id}`, { method: 'DELETE' });
      loadData();
    };

    window.showRelation = async function(id, rel) {
      document.getElementById('rel-title').textContent = rel + ' for ' + id.substring(0,8) + '...';
      document.getElementById('rel-body').textContent = 'Loading...';
      relDialog.showModal();
      const res = await fetch(`${API}/${id}/${rel}`);
      const data = await res.json();
      document.getElementById('rel-body').textContent = JSON.stringify(data, null, 2);
    };

    loadData();
  </script>
</Base>
