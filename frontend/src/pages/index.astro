---
import Base from "../layouts/Base.astro";
---

<Base title="Mercado Peruano de Predicciones" description="Apuesta en los eventos más relevantes del Perú. Predice el futuro y gana.">
  <main class="min-h-[calc(100vh-4rem)]">
    <!-- Header Stats -->
    <div class="border-b border-neutral-800 bg-neutral-900/50">
      <div class="mx-auto max-w-7xl px-6 py-4">
        <div class="flex flex-wrap items-center justify-between gap-4">
          <div class="flex items-center gap-8">
            <div>
              <p class="text-xs text-neutral-500">Volumen Total</p>
              <p class="text-xl font-bold text-white">S/ 2.4M</p>
            </div>
            <div class="h-8 w-px bg-neutral-800"></div>
            <div>
              <p class="text-xs text-neutral-500">Mercados Activos</p>
              <p class="text-xl font-bold text-white">47</p>
            </div>
            <div class="h-8 w-px bg-neutral-800"></div>
            <div>
              <p class="text-xs text-neutral-500">Apostadores</p>
              <p class="text-xl font-bold text-white">12,847</p>
            </div>
          </div>
          <div class="flex items-center gap-3">
            <div class="flex items-center gap-2 rounded-lg bg-neutral-800 px-3 py-1.5">
              <span class="h-2 w-2 rounded-full bg-red-500"></span>
              <span class="text-sm text-neutral-300">SOL</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="mx-auto max-w-7xl px-6 py-8">
      <!-- Hero Section -->
      <div class="mb-12 text-center">
        <h1 class="text-4xl font-bold text-white md:text-5xl">
          <span class="text-red-600">Pronóstico</span> Peru
        </h1>
        <p class="mx-auto mt-4 max-w-2xl text-lg text-neutral-400">
          Apuesta en los eventos más relevantes del Perú. Política, deportes, economía y más.
        </p>
        <div class="mt-6 flex justify-center gap-4">
          <a href="/markets/new" class="rounded-xl bg-red-600 px-6 py-2.5 text-sm font-semibold text-white shadow-lg shadow-red-600/30 transition hover:bg-red-500">
            Crear Mercado
          </a>
          <button class="rounded-xl border border-neutral-700 px-6 py-2.5 text-sm font-medium text-neutral-300 transition hover:border-neutral-500 hover:text-white">
            Cómo Funciona
          </button>
        </div>
      </div>

      <!-- Category Filters -->
      <div class="mb-8 flex flex-wrap gap-2">
        <button class="rounded-full bg-red-600 px-4 py-1.5 text-sm font-medium text-white">Todos</button>
        <button class="rounded-full bg-neutral-800 px-4 py-1.5 text-sm font-medium text-neutral-400 hover:bg-neutral-700 hover:text-white">Política</button>
        <button class="rounded-full bg-neutral-800 px-4 py-1.5 text-sm font-medium text-neutral-400 hover:bg-neutral-700 hover:text-white">Deportes</button>
        <button class="rounded-full bg-neutral-800 px-4 py-1.5 text-sm font-medium text-neutral-400 hover:bg-neutral-700 hover:text-white">Economía</button>
        <button class="rounded-full bg-neutral-800 px-4 py-1.5 text-sm font-medium text-neutral-400 hover:bg-neutral-700 hover:text-white">Entretenimiento</button>
        <button class="rounded-full bg-neutral-800 px-4 py-1.5 text-sm font-medium text-neutral-400 hover:bg-neutral-700 hover:text-white">Crypto</button>
      </div>

      <!-- Live Markets -->
      <section>
        <div class="mb-6 flex items-center justify-between">
          <h2 class="text-xl font-semibold text-white">🔥 Mercados en Vivo</h2>
          <div class="flex items-center gap-2 text-sm text-neutral-400">
            <span class="h-2 w-2 rounded-full bg-green-500 animate-pulse"></span>
            Actualizado en tiempo real
          </div>
        </div>

        <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
          <!-- Market Card 1 -->
          <a href="/markets/ganador-eliminatorias-2026" class="group rounded-2xl border border-neutral-800 bg-neutral-900 p-5 transition hover:border-red-600/50 hover:bg-neutral-800/50">
            <div class="mb-3 flex items-center justify-between">
              <span class="rounded-full bg-red-600/20 px-2 py-0.5 text-xs font-medium text-red-400">Política</span>
              <span class="text-xs text-neutral-500">Expira en 15 días</span>
            </div>
            <h3 class="mb-4 text-lg font-semibold text-white group-hover:text-red-400">
              ¿Perú clasificará al Mundial 2026?
            </h3>
            <div class="space-y-3">
              <div class="flex items-center justify-between">
                <span class="text-sm text-neutral-400">Sí</span>
                <div class="flex items-center gap-3">
                  <div class="h-2 w-24 rounded-full bg-neutral-700">
                    <div class="h-2 w-14 rounded-full bg-green-500"></div>
                  </div>
                  <span class="font-mono text-sm font-semibold text-green-400">72¢</span>
                </div>
              </div>
              <div class="flex items-center justify-between">
                <span class="text-sm text-neutral-400">No</span>
                <div class="flex items-center gap-3">
                  <div class="h-2 w-24 rounded-full bg-neutral-700">
                    <div class="h-2 w-10 rounded-full bg-red-500"></div>
                  </div>
                  <span class="font-mono text-sm font-semibold text-red-400">28¢</span>
                </div>
              </div>
            </div>
            <div class="mt-4 flex items-center justify-between border-t border-neutral-800 pt-3">
              <span class="text-xs text-neutral-500">Vol: S/ 45,230</span>
              <span class="text-xs text-neutral-500">1,247 apostadores</span>
            </div>
          </a>

          <!-- Market Card 2 -->
          <a href="/markets/proximo-presidente" class="group rounded-2xl border border-neutral-800 bg-neutral-900 p-5 transition hover:border-red-600/50 hover:bg-neutral-800/50">
            <div class="mb-3 flex items-center justify-between">
              <span class="rounded-full bg-red-600/20 px-2 py-0.5 text-xs font-medium text-red-400">Política</span>
              <span class="text-xs text-neutral-500">Expira en 89 días</span>
            </div>
            <h3 class="mb-4 text-lg font-semibold text-white group-hover:text-red-400">
              ¿Quién será presidente 2026-2030?
            </h3>
            <div class="space-y-3">
              <div class="flex items-center justify-between">
                <span class="text-sm text-neutral-400">Margarita Pando</span>
                <span class="font-mono text-sm font-semibold text-green-400">35¢</span>
              </div>
              <div class="flex items-center justify-between">
                <span class="text-sm text-neutral-400">Rafael López</span>
                <span class="font-mono text-sm font-semibold text-neutral-400">28¢</span>
              </div>
              <div class="flex items-center justify-between">
                <span class="text-sm text-neutral-400">Otro</span>
                <span class="font-mono text-sm font-semibold text-neutral-400">37¢</span>
              </div>
            </div>
            <div class="mt-4 flex items-center justify-between border-t border-neutral-800 pt-3">
              <span class="text-xs text-neutral-500">Vol: S/ 128,450</span>
              <span class="text-xs text-neutral-500">3,891 apostadores</span>
            </div>
          </a>

          <!-- Market Card 3 -->
          <a href="/markets/liga1-2025" class="group rounded-2xl border border-neutral-800 bg-neutral-900 p-5 transition hover:border-red-600/50 hover:bg-neutral-800/50">
            <div class="mb-3 flex items-center justify-between">
              <span class="rounded-full bg-blue-600/20 px-2 py-0.5 text-xs font-medium text-blue-400">Deportes</span>
              <span class="text-xs text-neutral-500">Expira en 120 días</span>
            </div>
            <h3 class="mb-4 text-lg font-semibold text-white group-hover:text-red-400">
              ¿Universitario gana la Liga 1 2025?
            </h3>
            <div class="space-y-3">
              <div class="flex items-center justify-between">
                <span class="text-sm text-neutral-400">Sí</span>
                <div class="flex items-center gap-3">
                  <div class="h-2 w-24 rounded-full bg-neutral-700">
                    <div class="h-2 w-18 rounded-full bg-green-500"></div>
                  </div>
                  <span class="font-mono text-sm font-semibold text-green-400">62¢</span>
                </div>
              </div>
              <div class="flex items-center justify-between">
                <span class="text-sm text-neutral-400">No</span>
                <div class="flex items-center gap-3">
                  <div class="h-2 w-24 rounded-full bg-neutral-700">
                    <div class="h-2 w-6 rounded-full bg-red-500"></div>
                  </div>
                  <span class="font-mono text-sm font-semibold text-red-400">38¢</span>
                </div>
              </div>
            </div>
            <div class="mt-4 flex items-center justify-between border-t border-neutral-800 pt-3">
              <span class="text-xs text-neutral-500">Vol: S/ 89,120</span>
              <span class="text-xs text-neutral-500">2,104 apostadores</span>
            </div>
          </a>

          <!-- Market Card 4 -->
          <a href="/markets/dolar-diciembre" class="group rounded-2xl border border-neutral-800 bg-neutral-900 p-5 transition hover:border-red-600/50 hover:bg-neutral-800/50">
            <div class="mb-3 flex items-center justify-between">
              <span class="rounded-full bg-yellow-600/20 px-2 py-0.5 text-xs font-medium text-yellow-400">Economía</span>
              <span class="text-xs text-neutral-500">Expira en 45 días</span>
            </div>
            <h3 class="mb-4 text-lg font-semibold text-white group-hover:text-red-400">
              ¿El dólar supera S/ 4.00 en diciembre?
            </h3>
            <div class="space-y-3">
              <div class="flex items-center justify-between">
                <span class="text-sm text-neutral-400">Sí</span>
                <div class="flex items-center gap-3">
                  <div class="h-2 w-24 rounded-full bg-neutral-700">
                    <div class="h-2 w-8 rounded-full bg-green-500"></div>
                  </div>
                  <span class="font-mono text-sm font-semibold text-green-400">45¢</span>
                </div>
              </div>
              <div class="flex items-center justify-between">
                <span class="text-sm text-neutral-400">No</span>
                <div class="flex items-center gap-3">
                  <div class="h-2 w-24 rounded-full bg-neutral-700">
                    <div class="h-2 w-16 rounded-full bg-red-500"></div>
                  </div>
                  <span class="font-mono text-sm font-semibold text-red-400">55¢</span>
                </div>
              </div>
            </div>
            <div class="mt-4 flex items-center justify-between border-t border-neutral-800 pt-3">
              <span class="text-xs text-neutral-500">Vol: S/ 67,890</span>
              <span class="text-xs text-neutral-500">1,567 apostadores</span>
            </div>
          </a>

          <!-- Market Card 5 -->
          <a href="/markets/miss-universo-2025" class="group rounded-2xl border border-neutral-800 bg-neutral-900 p-5 transition hover:border-red-600/50 hover:bg-neutral-800/50">
            <div class="mb-3 flex items-center justify-between">
              <span class="rounded-full bg-pink-600/20 px-2 py-0.5 text-xs font-medium text-pink-400">Entretenimiento</span>
              <span class="text-xs text-neutral-500">Expira en 60 días</span>
            </div>
            <h3 class="mb-4 text-lg font-semibold text-white group-hover:text-red-400">
              ¿Perú queda top 5 en Miss Universo 2025?
            </h3>
            <div class="space-y-3">
              <div class="flex items-center justify-between">
                <span class="text-sm text-neutral-400">Sí</span>
                <div class="flex items-center gap-3">
                  <div class="h-2 w-24 rounded-full bg-neutral-700">
                    <div class="h-2 w-10 rounded-full bg-green-500"></div>
                  </div>
                  <span class="font-mono text-sm font-semibold text-green-400">28¢</span>
                </div>
              </div>
              <div class="flex items-center justify-between">
                <span class="text-sm text-neutral-400">No</span>
                <div class="flex items-center gap-3">
                  <div class="h-2 w-24 rounded-full bg-neutral-700">
                    <div class="h-2 w-14 rounded-full bg-red-500"></div>
                  </div>
                  <span class="font-mono text-sm font-semibold text-red-400">72¢</span>
                </div>
              </div>
            </div>
            <div class="mt-4 flex items-center justify-between border-t border-neutral-800 pt-3">
              <span class="text-xs text-neutral-500">Vol: S/ 23,450</span>
              <span class="text-xs text-neutral-500">892 apostadores</span>
            </div>
          </a>

          <!-- Market Card 6 -->
          <a href="/markets/btc-navidad" class="group rounded-2xl border border-neutral-800 bg-neutral-900 p-5 transition hover:border-red-600/50 hover:bg-neutral-800/50">
            <div class="mb-3 flex items-center justify-between">
              <span class="rounded-full bg-orange-600/20 px-2 py-0.5 text-xs font-medium text-orange-400">Crypto</span>
              <span class="text-xs text-neutral-500">Expira en 30 días</span>
            </div>
            <h3 class="mb-4 text-lg font-semibold text-white group-hover:text-red-400">
              ¿BTC supera $100k antes de Navidad?
            </h3>
            <div class="space-y-3">
              <div class="flex items-center justify-between">
                <span class="text-sm text-neutral-400">Sí</span>
                <div class="flex items-center gap-3">
                  <div class="h-2 w-24 rounded-full bg-neutral-700">
                    <div class="h-2 w-16 rounded-full bg-green-500"></div>
                  </div>
                  <span class="font-mono text-sm font-semibold text-green-400">58¢</span>
                </div>
              </div>
              <div class="flex items-center justify-between">
                <span class="text-sm text-neutral-400">No</span>
                <div class="flex items-center gap-3">
                  <div class="h-2 w-24 rounded-full bg-neutral-700">
                    <div class="h-2 w-8 rounded-full bg-red-500"></div>
                  </div>
                  <span class="font-mono text-sm font-semibold text-red-400">42¢</span>
                </div>
              </div>
            </div>
            <div class="mt-4 flex items-center justify-between border-t border-neutral-800 pt-3">
              <span class="text-xs text-neutral-500">Vol: S/ 156,780</span>
              <span class="text-xs text-neutral-500">4,231 apostadores</span>
            </div>
          </a>
        </div>
      </section>

      <!-- Trending Section -->
      <section class="mt-16">
        <h2 class="mb-6 text-xl font-semibold text-white">📈 Más Negociados</h2>
        <div class="rounded-2xl border border-neutral-800 bg-neutral-900">
          <div class="grid grid-cols-4 gap-4 border-b border-neutral-800 px-5 py-3 text-xs font-medium uppercase tracking-wider text-neutral-500">
            <div>Mercado</div>
            <div class="text-right">Precio</div>
            <div class="text-right">Volumen</div>
            <div class="text-right">Cambio</div>
          </div>
          <div class="divide-y divide-neutral-800">
            <a href="/markets/dolar-diciembre" class="grid grid-cols-4 items-center gap-4 px-5 py-4 transition hover:bg-neutral-800/50">
              <div>
                <p class="font-medium text-white">¿Dólar > S/ 4.00 en dic?</p>
                <p class="text-xs text-neutral-500">Economía</p>
              </div>
              <div class="text-right font-mono text-green-400">55¢</div>
              <div class="text-right text-sm text-neutral-400">S/ 67.8K</div>
              <div class="text-right text-sm text-red-400">-3.2%</div>
            </a>
            <a href="/markets/proximo-presidente" class="grid grid-cols-4 items-center gap-4 px-5 py-4 transition hover:bg-neutral-800/50">
              <div>
                <p class="font-medium text-white">¿Quién gana elecciones 2026?</p>
                <p class="text-xs text-neutral-500">Política</p>
              </div>
              <div class="text-right font-mono text-green-400">35¢</div>
              <div class="text-right text-sm text-neutral-400">S/ 128K</div>
              <div class="text-right text-sm text-green-400">+5.1%</div>
            </a>
            <a href="/markets/btc-navidad" class="grid grid-cols-4 items-center gap-4 px-5 py-4 transition hover:bg-neutral-800/50">
              <div>
                <p class="font-medium text-white">¿BTC > $100k navidad?</p>
                <p class="text-xs text-neutral-500">Crypto</p>
              </div>
              <div class="text-right font-mono text-green-400">58¢</div>
              <div class="text-right text-sm text-neutral-400">S/ 156K</div>
              <div class="text-right text-sm text-green-400">+12.4%</div>
            </a>
          </div>
        </div>
      </section>
    </div>
  </main>
</Base>
