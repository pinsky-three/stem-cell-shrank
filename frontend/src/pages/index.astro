---
import Base from "../layouts/Base.astro";
---
<Base title="Stem Cell" description="Build apps and websites by chatting with AI. Describe what you want, watch it come to life, refine and ship.">
  <main class="flex min-h-[calc(100vh-4rem)] flex-col items-center justify-center px-6 py-24">

    <!-- Badge -->
    <div class="inline-flex items-center gap-2 rounded-full border border-neutral-800 bg-neutral-900/60 px-4 py-1.5 text-xs font-medium text-neutral-400">
      <span class="h-1.5 w-1.5 rounded-full bg-green-400 animate-pulse"></span>
      AI App Builder
    </div>

    <!-- Headline -->
    <h1 class="mt-8 max-w-3xl text-center text-5xl font-extrabold tracking-tight sm:text-6xl lg:text-7xl">
      Build something
      <span class="bg-linear-to-r from-indigo-400 via-purple-400 to-pink-400 bg-clip-text text-transparent">
        extraordinary
      </span>
    </h1>

    <p class="mx-auto mt-6 max-w-xl text-center text-lg leading-relaxed text-neutral-400">
      Create apps and websites by chatting with AI.
      Describe your idea and watch it come to life.
    </p>

    <!-- Chat input hero -->
    <div class="relative mx-auto mt-10 w-full max-w-2xl">
      <div class="rounded-2xl border border-neutral-700/50 bg-neutral-900/80 p-1.5 shadow-2xl shadow-indigo-600/5 backdrop-blur-sm transition focus-within:border-indigo-500/50 focus-within:shadow-indigo-500/10">
        <div class="flex items-end gap-2 rounded-xl bg-neutral-800/50 px-4 py-3">
          <textarea
            id="prompt-input"
            placeholder="Ask Stem Cell to create a landing page for my..."
            rows="2"
            class="flex-1 resize-none bg-transparent text-sm text-neutral-100 placeholder:text-neutral-500 focus:outline-none"
          ></textarea>
          <button
            id="build-btn"
            class="flex items-center gap-2 rounded-xl bg-indigo-600 px-5 py-2.5 text-sm font-semibold text-white shadow-lg shadow-indigo-600/20 transition hover:bg-indigo-500 hover:shadow-indigo-500/30 active:scale-95"
          >
            Build
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </button>
        </div>
      </div>
      <p class="mt-3 text-center text-xs text-neutral-600">
        No credit card required &middot; Start building for free
      </p>
    </div>

    <!-- How it works -->
    <section class="mx-auto mt-32 w-full max-w-5xl">
      <h2 class="text-center text-sm font-semibold uppercase tracking-widest text-neutral-500">
        How it works
      </h2>
      <div class="mt-10 grid gap-8 sm:grid-cols-3">
        <div class="rounded-2xl border border-neutral-800 bg-neutral-900/40 p-8 text-center">
          <div class="mx-auto mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-indigo-600/10 text-indigo-400">
            <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-neutral-100">Start with an idea</h3>
          <p class="mt-3 text-sm leading-relaxed text-neutral-500">
            Describe the app or website you want to create, or drop in screenshots and docs.
          </p>
        </div>
        <div class="rounded-2xl border border-neutral-800 bg-neutral-900/40 p-8 text-center">
          <div class="mx-auto mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-purple-600/10 text-purple-400">
            <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-neutral-100">Watch it come to life</h3>
          <p class="mt-3 text-sm leading-relaxed text-neutral-500">
            See your vision transform into a working prototype in real-time as AI builds it for you.
          </p>
        </div>
        <div class="rounded-2xl border border-neutral-800 bg-neutral-900/40 p-8 text-center">
          <div class="mx-auto mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-pink-600/10 text-pink-400">
            <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-neutral-100">Refine and ship</h3>
          <p class="mt-3 text-sm leading-relaxed text-neutral-500">
            Iterate on your creation with simple feedback and deploy it to the world with one click.
          </p>
        </div>
      </div>
    </section>

    <!-- Stats -->
    <section class="mx-auto mt-32 w-full max-w-4xl">
      <div class="grid gap-8 rounded-2xl border border-neutral-800 bg-neutral-900/30 px-8 py-12 text-center sm:grid-cols-3">
        <div>
          <p class="text-4xl font-extrabold tracking-tight text-indigo-400">100K+</p>
          <p class="mt-2 text-sm text-neutral-500">Projects built</p>
        </div>
        <div>
          <p class="text-4xl font-extrabold tracking-tight text-purple-400">50K+</p>
          <p class="mt-2 text-sm text-neutral-500">Builders worldwide</p>
        </div>
        <div>
          <p class="text-4xl font-extrabold tracking-tight text-pink-400">1M+</p>
          <p class="mt-2 text-sm text-neutral-500">AI builds per month</p>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="mx-auto mt-32 mb-16 w-full max-w-2xl text-center">
      <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">
        Ready to build?
      </h2>
      <p class="mt-4 text-neutral-400">
        Turn your ideas into reality. Start building for free today.
      </p>
      <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a href="/admin" class="rounded-xl bg-indigo-600 px-8 py-3.5 text-sm font-semibold text-white shadow-lg shadow-indigo-600/20 transition hover:bg-indigo-500 hover:shadow-indigo-500/30">
          Get started free
        </a>
        <a href="/api/docs" class="rounded-xl border border-neutral-700 px-8 py-3.5 text-sm font-medium text-neutral-300 transition hover:border-neutral-500 hover:text-white">
          API Documentation
        </a>
      </div>
    </section>
  </main>
</Base>
