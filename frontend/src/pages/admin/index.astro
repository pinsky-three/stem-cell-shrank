    fetch('/api/invoices').then(r=>r.json()).then(d=>{
      document.getElementById('count-invoices').textContent=d.length+' records';
    }).catch(()=>{
      document.getElementById('count-invoices').textContent='--';
    });
    fetch('/api/line_items').then(r=>r.json()).then(d=>{
      document.getElementById('count-line_items').textContent=d.length+' records';
    }).catch(()=>{
      document.getElementById('count-line_items').textContent='--';
    });
    fetch('/api/payments').then(r=>r.json()).then(d=>{
