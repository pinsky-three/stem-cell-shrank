<!-- @generated from specs/self.yaml + systems.yaml — do not edit -->
---
import Base from "../../layouts/Base.astro";
---
<Base title="Admin Dashboard" noindex={true}>
  <div class="mx-auto max-w-6xl px-6 py-12">
    <div class="flex items-center justify-between">
      <h1 class="text-3xl font-bold tracking-tight">Admin Dashboard</h1>
      <a href="/api/docs" class="rounded-lg border border-neutral-700 px-4 py-2 text-sm font-medium text-neutral-300 transition hover:border-indigo-500 hover:text-indigo-400">
        API Docs
      </a>
    </div>

    <h2 class="mt-10 text-xl font-bold tracking-tight text-neutral-300">Entities</h2>
    <div class="mt-6 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      <a href="/admin/organizations" class="group rounded-xl border border-neutral-800 bg-neutral-900/50 p-6 transition hover:border-indigo-600/40 hover:bg-neutral-900">
        <h3 class="text-lg font-semibold">Organization</h3>
        <p id="count-organizations" class="mt-2 text-2xl font-bold text-indigo-400">...</p>
        <p class="mt-1 text-xs text-neutral-500">/admin/organizations</p>
      </a>
      <a href="/admin/departments" class="group rounded-xl border border-neutral-800 bg-neutral-900/50 p-6 transition hover:border-indigo-600/40 hover:bg-neutral-900">
        <h3 class="text-lg font-semibold">Department</h3>
        <p id="count-departments" class="mt-2 text-2xl font-bold text-indigo-400">...</p>
        <p class="mt-1 text-xs text-neutral-500">/admin/departments</p>
      </a>
      <a href="/admin/roles" class="group rounded-xl border border-neutral-800 bg-neutral-900/50 p-6 transition hover:border-indigo-600/40 hover:bg-neutral-900">
        <h3 class="text-lg font-semibold">Role</h3>
        <p id="count-roles" class="mt-2 text-2xl font-bold text-indigo-400">...</p>
        <p class="mt-1 text-xs text-neutral-500">/admin/roles</p>
      </a>
      <a href="/admin/users" class="group rounded-xl border border-neutral-800 bg-neutral-900/50 p-6 transition hover:border-indigo-600/40 hover:bg-neutral-900">
        <h3 class="text-lg font-semibold">User</h3>
        <p id="count-users" class="mt-2 text-2xl font-bold text-indigo-400">...</p>
        <p class="mt-1 text-xs text-neutral-500">/admin/users</p>
      </a>
      <a href="/admin/clients" class="group rounded-xl border border-neutral-800 bg-neutral-900/50 p-6 transition hover:border-indigo-600/40 hover:bg-neutral-900">
        <h3 class="text-lg font-semibold">Client</h3>
        <p id="count-clients" class="mt-2 text-2xl font-bold text-indigo-400">...</p>
        <p class="mt-1 text-xs text-neutral-500">/admin/clients</p>
      </a>
      <a href="/admin/projects" class="group rounded-xl border border-neutral-800 bg-neutral-900/50 p-6 transition hover:border-indigo-600/40 hover:bg-neutral-900">
        <h3 class="text-lg font-semibold">Project</h3>
        <p id="count-projects" class="mt-2 text-2xl font-bold text-indigo-400">...</p>
        <p class="mt-1 text-xs text-neutral-500">/admin/projects</p>
      </a>
      <a href="/admin/milestones" class="group rounded-xl border border-neutral-800 bg-neutral-900/50 p-6 transition hover:border-indigo-600/40 hover:bg-neutral-900">
        <h3 class="text-lg font-semibold">Milestone</h3>
        <p id="count-milestones" class="mt-2 text-2xl font-bold text-indigo-400">...</p>
        <p class="mt-1 text-xs text-neutral-500">/admin/milestones</p>
      </a>
      <a href="/admin/sprints" class="group rounded-xl border border-neutral-800 bg-neutral-900/50 p-6 transition hover:border-indigo-600/40 hover:bg-neutral-900">
        <h3 class="text-lg font-semibold">Sprint</h3>
        <p id="count-sprints" class="mt-2 text-2xl font-bold text-indigo-400">...</p>
        <p class="mt-1 text-xs text-neutral-500">/admin/sprints</p>
      </a>
      <a href="/admin/categories" class="group rounded-xl border border-neutral-800 bg-neutral-900/50 p-6 transition hover:border-indigo-600/40 hover:bg-neutral-900">
        <h3 class="text-lg font-semibold">Category</h3>
        <p id="count-categories" class="mt-2 text-2xl font-bold text-indigo-400">...</p>
        <p class="mt-1 text-xs text-neutral-500">/admin/categories</p>
      </a>
      <a href="/admin/tasks" class="group rounded-xl border border-neutral-800 bg-neutral-900/50 p-6 transition hover:border-indigo-600/40 hover:bg-neutral-900">
        <h3 class="text-lg font-semibold">Task</h3>
        <p id="count-tasks" class="mt-2 text-2xl font-bold text-indigo-400">...</p>
        <p class="mt-1 text-xs text-neutral-500">/admin/tasks</p>
      </a>
      <a href="/admin/comments" class="group rounded-xl border border-neutral-800 bg-neutral-900/50 p-6 transition hover:border-indigo-600/40 hover:bg-neutral-900">
        <h3 class="text-lg font-semibold">Comment</h3>
        <p id="count-comments" class="mt-2 text-2xl font-bold text-indigo-400">...</p>
        <p class="mt-1 text-xs text-neutral-500">/admin/comments</p>
      </a>
      <a href="/admin/time_entries" class="group rounded-xl border border-neutral-800 bg-neutral-900/50 p-6 transition hover:border-indigo-600/40 hover:bg-neutral-900">
        <h3 class="text-lg font-semibold">TimeEntry</h3>
        <p id="count-time_entries" class="mt-2 text-2xl font-bold text-indigo-400">...</p>
        <p class="mt-1 text-xs text-neutral-500">/admin/time_entries</p>
      </a>
      <a href="/admin/contracts" class="group rounded-xl border border-neutral-800 bg-neutral-900/50 p-6 transition hover:border-indigo-600/40 hover:bg-neutral-900">
        <h3 class="text-lg font-semibold">Contract</h3>
        <p id="count-contracts" class="mt-2 text-2xl font-bold text-indigo-400">...</p>
        <p class="mt-1 text-xs text-neutral-500">/admin/contracts</p>
      </a>
      <a href="/admin/invoices" class="group rounded-xl border border-neutral-800 bg-neutral-900/50 p-6 transition hover:border-indigo-600/40 hover:bg-neutral-900">
        <h3 class="text-lg font-semibold">Invoice</h3>
        <p id="count-invoices" class="mt-2 text-2xl font-bold text-indigo-400">...</p>
        <p class="mt-1 text-xs text-neutral-500">/admin/invoices</p>
      </a>
      <a href="/admin/line_items" class="group rounded-xl border border-neutral-800 bg-neutral-900/50 p-6 transition hover:border-indigo-600/40 hover:bg-neutral-900">
        <h3 class="text-lg font-semibold">LineItem</h3>
        <p id="count-line_items" class="mt-2 text-2xl font-bold text-indigo-400">...</p>
        <p class="mt-1 text-xs text-neutral-500">/admin/line_items</p>
      </a>
      <a href="/admin/payments" class="group rounded-xl border border-neutral-800 bg-neutral-900/50 p-6 transition hover:border-indigo-600/40 hover:bg-neutral-900">
        <h3 class="text-lg font-semibold">Payment</h3>
        <p id="count-payments" class="mt-2 text-2xl font-bold text-indigo-400">...</p>
        <p class="mt-1 text-xs text-neutral-500">/admin/payments</p>
      </a>
    </div>

    <h2 class="mt-14 text-xl font-bold tracking-tight text-neutral-300">Systems</h2>
    <p class="mt-1 text-sm text-neutral-500">Declarative business workflows generated from systems.yaml</p>
    <div class="mt-6 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      <a href="/admin/systems/record_invoice_payment" class="group rounded-xl border border-neutral-800 bg-neutral-900/50 p-6 transition hover:border-emerald-600/40 hover:bg-neutral-900">
        <h3 class="text-lg font-semibold">RecordInvoicePayment</h3>
        <p class="mt-2 text-sm text-neutral-400">Processes a payment charge, records it, and marks the invoice as paid</p>
        <p class="mt-2 text-xs text-neutral-500">6 inputs &middot; POST /api/systems/record_invoice_payment</p>
      </a>
      <a href="/admin/systems/assign_task" class="group rounded-xl border border-neutral-800 bg-neutral-900/50 p-6 transition hover:border-emerald-600/40 hover:bg-neutral-900">
        <h3 class="text-lg font-semibold">AssignTask</h3>
        <p class="mt-2 text-sm text-neutral-400">Assigns a task to an active user</p>
        <p class="mt-2 text-xs text-neutral-500">2 inputs &middot; POST /api/systems/assign_task</p>
      </a>
      <a href="/admin/systems/close_sprint" class="group rounded-xl border border-neutral-800 bg-neutral-900/50 p-6 transition hover:border-emerald-600/40 hover:bg-neutral-900">
        <h3 class="text-lg font-semibold">CloseSprint</h3>
        <p class="mt-2 text-sm text-neutral-400">Deactivates a sprint and loads its remaining tasks for review</p>
        <p class="mt-2 text-xs text-neutral-500">1 inputs &middot; POST /api/systems/close_sprint</p>
      </a>
      <a href="/admin/systems/log_billable_time" class="group rounded-xl border border-neutral-800 bg-neutral-900/50 p-6 transition hover:border-emerald-600/40 hover:bg-neutral-900">
        <h3 class="text-lg font-semibold">LogBillableTime</h3>
        <p class="mt-2 text-sm text-neutral-400">Creates a time entry and sends a receipt email when billable</p>
        <p class="mt-2 text-xs text-neutral-500">6 inputs &middot; POST /api/systems/log_billable_time</p>
      </a>
      <a href="/admin/systems/remove_comment" class="group rounded-xl border border-neutral-800 bg-neutral-900/50 p-6 transition hover:border-emerald-600/40 hover:bg-neutral-900">
        <h3 class="text-lg font-semibold">RemoveComment</h3>
        <p class="mt-2 text-sm text-neutral-400">Deletes a comment after verifying the requesting user is the author</p>
        <p class="mt-2 text-xs text-neutral-500">2 inputs &middot; POST /api/systems/remove_comment</p>
      </a>
    </div>
  </div>

  <script>
    fetch('/api/organizations').then(r=>r.json()).then(d=>{
      document.getElementById('count-organizations').textContent=d.length+' records';
    }).catch(()=>{
      document.getElementById('count-organizations').textContent='--';
    });
    fetch('/api/departments').then(r=>r.json()).then(d=>{
      document.getElementById('count-departments').textContent=d.length+' records';
    }).catch(()=>{
