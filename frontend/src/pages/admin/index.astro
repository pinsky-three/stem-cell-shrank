<!-- @generated from specs/self.yaml + systems.yaml — do not edit -->
---
import Base from "../../layouts/Base.astro";
---
<Base title="Admin Dashboard" noindex={true}>
  <div class="mx-auto max-w-6xl px-6 py-12">
    <div class="flex items-center justify-between">
      <h1 class="text-3xl font-bold tracking-tight">Admin Dashboard</h1>
      <a href="/api/docs" class="rounded-lg border border-neutral-700 px-4 py-2 text-sm font-medium text-neutral-300 transition hover:border-indigo-500 hover:text-indigo-400">
        API Docs
      </a>
    </div>

    <h2 class="mt-10 text-xl font-bold tracking-tight text-neutral-300">Entities</h2>
    <div class="mt-6 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      <a href="/admin/organizations" class="group rounded-xl border border-neutral-800 bg-neutral-900/50 p-6 transition hover:border-indigo-600/40 hover:bg-neutral-900">
        <h3 class="text-lg font-semibold">Organization</h3>
        <p id="count-organizations" class="mt-2 text-2xl font-bold text-indigo-400">...</p>
        <p class="mt-1 text-xs text-neutral-500">/admin/organizations</p>
      </a>
      <a href="/admin/users" class="group rounded-xl border border-neutral-800 bg-neutral-900/50 p-6 transition hover:border-indigo-600/40 hover:bg-neutral-900">
        <h3 class="text-lg font-semibold">User</h3>
        <p id="count-users" class="mt-2 text-2xl font-bold text-indigo-400">...</p>
        <p class="mt-1 text-xs text-neutral-500">/admin/users</p>
      </a>
      <a href="/admin/memberships" class="group rounded-xl border border-neutral-800 bg-neutral-900/50 p-6 transition hover:border-indigo-600/40 hover:bg-neutral-900">
        <h3 class="text-lg font-semibold">Membership</h3>
        <p id="count-memberships" class="mt-2 text-2xl font-bold text-indigo-400">...</p>
        <p class="mt-1 text-xs text-neutral-500">/admin/memberships</p>
      </a>
      <a href="/admin/plans" class="group rounded-xl border border-neutral-800 bg-neutral-900/50 p-6 transition hover:border-indigo-600/40 hover:bg-neutral-900">
        <h3 class="text-lg font-semibold">Plan</h3>
        <p id="count-plans" class="mt-2 text-2xl font-bold text-indigo-400">...</p>
        <p class="mt-1 text-xs text-neutral-500">/admin/plans</p>
      </a>
      <a href="/admin/subscriptions" class="group rounded-xl border border-neutral-800 bg-neutral-900/50 p-6 transition hover:border-indigo-600/40 hover:bg-neutral-900">
        <h3 class="text-lg font-semibold">Subscription</h3>
        <p id="count-subscriptions" class="mt-2 text-2xl font-bold text-indigo-400">...</p>
        <p class="mt-1 text-xs text-neutral-500">/admin/subscriptions</p>
      </a>
      <a href="/admin/projects" class="group rounded-xl border border-neutral-800 bg-neutral-900/50 p-6 transition hover:border-indigo-600/40 hover:bg-neutral-900">
        <h3 class="text-lg font-semibold">Project</h3>
        <p id="count-projects" class="mt-2 text-2xl font-bold text-indigo-400">...</p>
        <p class="mt-1 text-xs text-neutral-500">/admin/projects</p>
      </a>
      <a href="/admin/conversations" class="group rounded-xl border border-neutral-800 bg-neutral-900/50 p-6 transition hover:border-indigo-600/40 hover:bg-neutral-900">
        <h3 class="text-lg font-semibold">Conversation</h3>
        <p id="count-conversations" class="mt-2 text-2xl font-bold text-indigo-400">...</p>
        <p class="mt-1 text-xs text-neutral-500">/admin/conversations</p>
      </a>
      <a href="/admin/messages" class="group rounded-xl border border-neutral-800 bg-neutral-900/50 p-6 transition hover:border-indigo-600/40 hover:bg-neutral-900">
        <h3 class="text-lg font-semibold">Message</h3>
        <p id="count-messages" class="mt-2 text-2xl font-bold text-indigo-400">...</p>
        <p class="mt-1 text-xs text-neutral-500">/admin/messages</p>
      </a>
      <a href="/admin/build_jobs" class="group rounded-xl border border-neutral-800 bg-neutral-900/50 p-6 transition hover:border-indigo-600/40 hover:bg-neutral-900">
        <h3 class="text-lg font-semibold">BuildJob</h3>
        <p id="count-build_jobs" class="mt-2 text-2xl font-bold text-indigo-400">...</p>
        <p class="mt-1 text-xs text-neutral-500">/admin/build_jobs</p>
      </a>
      <a href="/admin/artifacts" class="group rounded-xl border border-neutral-800 bg-neutral-900/50 p-6 transition hover:border-indigo-600/40 hover:bg-neutral-900">
        <h3 class="text-lg font-semibold">Artifact</h3>
        <p id="count-artifacts" class="mt-2 text-2xl font-bold text-indigo-400">...</p>
        <p class="mt-1 text-xs text-neutral-500">/admin/artifacts</p>
      </a>
      <a href="/admin/deployments" class="group rounded-xl border border-neutral-800 bg-neutral-900/50 p-6 transition hover:border-indigo-600/40 hover:bg-neutral-900">
        <h3 class="text-lg font-semibold">Deployment</h3>
        <p id="count-deployments" class="mt-2 text-2xl font-bold text-indigo-400">...</p>
        <p class="mt-1 text-xs text-neutral-500">/admin/deployments</p>
      </a>
      <a href="/admin/usage_records" class="group rounded-xl border border-neutral-800 bg-neutral-900/50 p-6 transition hover:border-indigo-600/40 hover:bg-neutral-900">
        <h3 class="text-lg font-semibold">UsageRecord</h3>
        <p id="count-usage_records" class="mt-2 text-2xl font-bold text-indigo-400">...</p>
        <p class="mt-1 text-xs text-neutral-500">/admin/usage_records</p>
      </a>
    </div>

    <h2 class="mt-14 text-xl font-bold tracking-tight text-neutral-300">Systems</h2>
    <p class="mt-1 text-sm text-neutral-500">Declarative business workflows generated from systems.yaml</p>
    <div class="mt-6 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      <a href="/admin/systems/create_project" class="group rounded-xl border border-neutral-800 bg-neutral-900/50 p-6 transition hover:border-emerald-600/40 hover:bg-neutral-900">
        <h3 class="text-lg font-semibold">CreateProject</h3>
        <p class="mt-2 text-sm text-neutral-400">Creates a new AI-builder project and its first conversation</p>
        <p class="mt-2 text-xs text-neutral-500">5 inputs &middot; POST /api/systems/create_project</p>
      </a>
      <a href="/admin/systems/send_message" class="group rounded-xl border border-neutral-800 bg-neutral-900/50 p-6 transition hover:border-emerald-600/40 hover:bg-neutral-900">
        <h3 class="text-lg font-semibold">SendMessage</h3>
        <p class="mt-2 text-sm text-neutral-400">Posts a user message to a conversation and queues an AI build job</p>
        <p class="mt-2 text-xs text-neutral-500">4 inputs &middot; POST /api/systems/send_message</p>
      </a>
      <a href="/admin/systems/run_build" class="group rounded-xl border border-neutral-800 bg-neutral-900/50 p-6 transition hover:border-emerald-600/40 hover:bg-neutral-900">
        <h3 class="text-lg font-semibold">RunBuild</h3>
        <p class="mt-2 text-sm text-neutral-400">Executes the AI code-generation pipeline: fetches project context, calls the AI provider, and writes artifacts</p>
        <p class="mt-2 text-xs text-neutral-500">1 inputs &middot; POST /api/systems/run_build</p>
      </a>
      <a href="/admin/systems/deploy_project" class="group rounded-xl border border-neutral-800 bg-neutral-900/50 p-6 transition hover:border-emerald-600/40 hover:bg-neutral-900">
        <h3 class="text-lg font-semibold">DeployProject</h3>
        <p class="mt-2 text-sm text-neutral-400">Deploys the latest successful build of a project to the hosting provider</p>
        <p class="mt-2 text-xs text-neutral-500">4 inputs &middot; POST /api/systems/deploy_project</p>
      </a>
      <a href="/admin/systems/upgrade_subscription" class="group rounded-xl border border-neutral-800 bg-neutral-900/50 p-6 transition hover:border-emerald-600/40 hover:bg-neutral-900">
        <h3 class="text-lg font-semibold">UpgradeSubscription</h3>
        <p class="mt-2 text-sm text-neutral-400">Changes an organization's plan and processes payment via the payment provider</p>
        <p class="mt-2 text-xs text-neutral-500">3 inputs &middot; POST /api/systems/upgrade_subscription</p>
      </a>
      <a href="/admin/systems/cleanup_deployments" class="group rounded-xl border border-neutral-800 bg-neutral-900/50 p-6 transition hover:border-emerald-600/40 hover:bg-neutral-900">
        <h3 class="text-lg font-semibold">CleanupDeployments</h3>
        <p class="mt-2 text-sm text-neutral-400">Stops running deployments older than max_age_minutes, kills their process, and removes the cloned repo from temp</p>
        <p class="mt-2 text-xs text-neutral-500">2 inputs &middot; POST /api/systems/cleanup_deployments</p>
      </a>
      <a href="/admin/systems/spawn_environment" class="group rounded-xl border border-neutral-800 bg-neutral-900/50 p-6 transition hover:border-emerald-600/40 hover:bg-neutral-900">
        <h3 class="text-lg font-semibold">SpawnEnvironment</h3>
        <p class="mt-2 text-sm text-neutral-400">Creates a project, queues a build job, and spawns a Podman container to clone a repo and run mise run dev</p>
        <p class="mt-2 text-xs text-neutral-500">3 inputs &middot; POST /api/systems/spawn_environment</p>
      </a>
    </div>
  </div>

  <script>
    fetch('/api/organizations').then(r=>r.json()).then(d=>{
      document.getElementById('count-organizations').textContent=d.length+' records';
    }).catch(()=>{
      document.getElementById('count-organizations').textContent='--';
    });
    fetch('/api/users').then(r=>r.json()).then(d=>{
      document.getElementById('count-users').textContent=d.length+' records';
    }).catch(()=>{
      document.getElementById('count-users').textContent='--';
    });
    fetch('/api/memberships').then(r=>r.json()).then(d=>{
      document.getElementById('count-memberships').textContent=d.length+' records';
    }).catch(()=>{
      document.getElementById('count-memberships').textContent='--';
    });
    fetch('/api/plans').then(r=>r.json()).then(d=>{
      document.getElementById('count-plans').textContent=d.length+' records';
    }).catch(()=>{
      document.getElementById('count-plans').textContent='--';
    });
    fetch('/api/subscriptions').then(r=>r.json()).then(d=>{
      document.getElementById('count-subscriptions').textContent=d.length+' records';
    }).catch(()=>{
      document.getElementById('count-subscriptions').textContent='--';
    });
    fetch('/api/projects').then(r=>r.json()).then(d=>{
      document.getElementById('count-projects').textContent=d.length+' records';
    }).catch(()=>{
      document.getElementById('count-projects').textContent='--';
    });
    fetch('/api/conversations').then(r=>r.json()).then(d=>{
      document.getElementById('count-conversations').textContent=d.length+' records';
    }).catch(()=>{
      document.getElementById('count-conversations').textContent='--';
    });
    fetch('/api/messages').then(r=>r.json()).then(d=>{
      document.getElementById('count-messages').textContent=d.length+' records';
    }).catch(()=>{
      document.getElementById('count-messages').textContent='--';
    });
    fetch('/api/build_jobs').then(r=>r.json()).then(d=>{
      document.getElementById('count-build_jobs').textContent=d.length+' records';
    }).catch(()=>{
      document.getElementById('count-build_jobs').textContent='--';
    });
    fetch('/api/artifacts').then(r=>r.json()).then(d=>{
      document.getElementById('count-artifacts').textContent=d.length+' records';
    }).catch(()=>{
      document.getElementById('count-artifacts').textContent='--';
    });
    fetch('/api/deployments').then(r=>r.json()).then(d=>{
      document.getElementById('count-deployments').textContent=d.length+' records';
    }).catch(()=>{
      document.getElementById('count-deployments').textContent='--';
    });
    fetch('/api/usage_records').then(r=>r.json()).then(d=>{
      document.getElementById('count-usage_records').textContent=d.length+' records';
    }).catch(()=>{
      document.getElementById('count-usage_records').textContent='--';
    });
  </script>
</Base>
