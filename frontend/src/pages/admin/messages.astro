<!-- @generated from specs/self.yaml — do not edit -->
---
import Base from "../../layouts/Base.astro";
---
<Base title="Message | Admin" noindex={true}>
  <div class="mx-auto max-w-7xl px-6 py-12">
    <div class="flex items-center justify-between">
      <div class="flex items-center gap-4">
        <a href="/admin" class="text-neutral-500 transition hover:text-neutral-300">&larr; Dashboard</a>
        <h1 class="text-3xl font-bold tracking-tight">Message</h1>
      </div>
      <button id="create-btn" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold transition hover:bg-indigo-500">
        + New message
      </button>
    </div>

    <!-- Data table -->
    <div class="mt-8 overflow-x-auto rounded-xl border border-neutral-800">
      <table class="w-full">
        <thead class="border-b border-neutral-800 bg-neutral-900/50">
          <tr>
          <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-neutral-400">id</th>
          <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-neutral-400">role</th>
          <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-neutral-400">content</th>
          <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-neutral-400">sort_order</th>
          <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-neutral-400">has_attachment</th>
          <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-neutral-400">conversation_id</th>
          <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-neutral-400">author_id</th>
          <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-neutral-400">actions</th>
          </tr>
        </thead>
        <tbody id="table-body" class="divide-y divide-neutral-800/50"></tbody>
      </table>
    </div>
  </div>

  <!-- Form dialog -->
  <dialog id="form-dialog" class="rounded-xl border border-neutral-700 bg-neutral-900 p-0 text-neutral-100 shadow-2xl backdrop:bg-black/60">
    <form id="entity-form" method="dialog" class="flex flex-col gap-4 p-6" style="min-width:380px">
      <h2 id="form-title" class="text-lg font-bold">New message</h2>
      <div class="flex flex-col gap-3">
        <input type="text" name="role" placeholder="role"
              class="rounded-lg border border-neutral-700 bg-neutral-800 px-3 py-2 text-sm text-neutral-100 placeholder:text-neutral-500 focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" required />
        <textarea name="content" placeholder="content" rows="2"
              class="rounded-lg border border-neutral-700 bg-neutral-800 px-3 py-2 text-sm text-neutral-100 placeholder:text-neutral-500 focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" required></textarea>
        <input type="number" name="sort_order" placeholder="sort_order" step="1"
              class="rounded-lg border border-neutral-700 bg-neutral-800 px-3 py-2 text-sm text-neutral-100 placeholder:text-neutral-500 focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" required />
        <label class="flex items-center gap-2 text-sm">
              <input type="checkbox" name="has_attachment" class="rounded border-neutral-600 bg-neutral-800 text-indigo-500 focus:ring-indigo-500" />
              has_attachment
            </label>
        <input type="text" name="conversation_id" placeholder="conversation_id (UUID)"
              pattern="[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}"
              class="rounded-lg border border-neutral-700 bg-neutral-800 px-3 py-2 text-sm text-neutral-100 placeholder:text-neutral-500 focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" required />
        <input type="text" name="author_id" placeholder="author_id (UUID)"
              pattern="[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}"
              class="rounded-lg border border-neutral-700 bg-neutral-800 px-3 py-2 text-sm text-neutral-100 placeholder:text-neutral-500 focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" required />
      </div>
      <div class="flex justify-end gap-3 pt-2">
        <button type="button" id="cancel-btn" class="rounded-lg border border-neutral-700 px-4 py-2 text-sm transition hover:bg-neutral-800">Cancel</button>
        <button type="submit" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold transition hover:bg-indigo-500">Save</button>
      </div>
    </form>
  </dialog>

  <!-- Relation panel -->
  <dialog id="rel-dialog" class="rounded-xl border border-neutral-700 bg-neutral-900 p-6 text-neutral-100 shadow-2xl backdrop:bg-black/60" style="min-width:400px;max-height:80vh">
    <div class="flex items-center justify-between mb-4">
      <h2 id="rel-title" class="text-lg font-bold"></h2>
      <button onclick="document.getElementById('rel-dialog').close()" class="text-neutral-500 hover:text-neutral-300">&times;</button>
    </div>
    <pre id="rel-body" class="overflow-auto text-xs text-neutral-300 bg-neutral-800 rounded-lg p-4 max-h-96"></pre>
  </dialog>

  <script>
    const API = '/api/messages';
    const dialog = document.getElementById('form-dialog');
    const form = document.getElementById('entity-form');
    const relDialog = document.getElementById('rel-dialog');
    let editingId = null;

    function renderRow(r) {
      return `<tr class="transition hover:bg-neutral-900/30">` +
        `<td class="px-4 py-3 font-mono text-xs text-neutral-500">${r.id.substring(0,8)}...</td>`+
        `<td class="px-4 py-3 text-sm text-neutral-300">${r.role??'—'}</td>`+
        `<td class="px-4 py-3 text-sm text-neutral-300">${r.content??'—'}</td>`+
        `<td class="px-4 py-3 text-sm text-neutral-300">${r.sort_order??'—'}</td>`+
        `<td class="px-4 py-3 text-sm">${r.has_attachment?'<span class="text-green-400">yes</span>':'<span class="text-red-400">no</span>'}</td>`+
        `<td class="px-4 py-3 font-mono text-xs"><a href="/admin/conversations" class="text-indigo-400 hover:underline">${r.conversation_id?r.conversation_id.substring(0,8)+'...':'—'}</a></td>`+
        `<td class="px-4 py-3 font-mono text-xs"><a href="/admin/users" class="text-indigo-400 hover:underline">${r.author_id?r.author_id.substring(0,8)+'...':'—'}</a></td>` +
        `<td class="px-4 py-3 text-sm flex gap-3">
          <button onclick="editItem('${r.id}')" class="text-indigo-400 hover:underline">edit</button>
          <button onclick="deleteItem('${r.id}')" class="text-red-400 hover:underline">del</button>
          <button onclick="showRelation('${r.id}','build_jobs')" class="text-indigo-400 hover:underline">build_jobs</button>
        </td></tr>`;
    }

    async function loadData() {
      const res = await fetch(API);
      const items = await res.json();
      document.getElementById('table-body').innerHTML = items.map(renderRow).join('');
    }

    document.getElementById('create-btn').addEventListener('click', () => {
      editingId = null;
      form.reset();
      document.getElementById('form-title').textContent = 'New message';
      dialog.showModal();
    });

    document.getElementById('cancel-btn').addEventListener('click', () => dialog.close());

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const body = {
        role: form.elements['role'].value,
        content: form.elements['content'].value,
        sort_order: form.elements['sort_order'].value ? Number(form.elements['sort_order'].value) : null,
        has_attachment: form.elements['has_attachment'].checked,
        conversation_id: form.elements['conversation_id'].value,
        author_id: form.elements['author_id'].value
      };
      const url = editingId ? `${API}/${editingId}` : API;
      const method = editingId ? 'PUT' : 'POST';
      await fetch(url, {
        method,
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
      dialog.close();
      loadData();
    });

    window.editItem = async function(id) {
      const res = await fetch(`${API}/${id}`);
      const item = await res.json();
      editingId = id;
      document.getElementById('form-title').textContent = 'Edit message';
      form.elements['role'].value = item.role ?? '';
      form.elements['content'].value = item.content ?? '';
      form.elements['sort_order'].value = item.sort_order ?? '';
      form.elements['has_attachment'].checked = item.has_attachment;
      form.elements['conversation_id'].value = item.conversation_id ?? '';
      form.elements['author_id'].value = item.author_id ?? '';
      dialog.showModal();
    };

    window.deleteItem = async function(id) {
      if (!confirm('Delete this message?')) return;
      await fetch(`${API}/${id}`, { method: 'DELETE' });
      loadData();
    };

    window.showRelation = async function(id, rel) {
      document.getElementById('rel-title').textContent = rel + ' for ' + id.substring(0,8) + '...';
      document.getElementById('rel-body').textContent = 'Loading...';
      relDialog.showModal();
      const res = await fetch(`${API}/${id}/${rel}`);
      const data = await res.json();
      document.getElementById('rel-body').textContent = JSON.stringify(data, null, 2);
    };

    loadData();
  </script>
</Base>
