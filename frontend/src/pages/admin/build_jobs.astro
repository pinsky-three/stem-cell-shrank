<!-- @generated from specs/self.yaml — do not edit -->
---
import Base from "../../layouts/Base.astro";
---
<Base title="BuildJob | Admin" noindex={true}>
  <div class="mx-auto max-w-7xl px-6 py-12">
    <div class="flex items-center justify-between">
      <div class="flex items-center gap-4">
        <a href="/admin" class="text-neutral-500 transition hover:text-neutral-300">&larr; Dashboard</a>
        <h1 class="text-3xl font-bold tracking-tight">BuildJob</h1>
      </div>
      <button id="create-btn" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold transition hover:bg-indigo-500">
        + New build_job
      </button>
    </div>

    <!-- Data table -->
    <div class="mt-8 overflow-x-auto rounded-xl border border-neutral-800">
      <table class="w-full">
        <thead class="border-b border-neutral-800 bg-neutral-900/50">
          <tr>
          <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-neutral-400">id</th>
          <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-neutral-400">status</th>
          <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-neutral-400">prompt_summary</th>
          <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-neutral-400">model</th>
          <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-neutral-400">tokens_used</th>
          <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-neutral-400">error_message</th>
          <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-neutral-400">duration_ms</th>
          <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-neutral-400">logs</th>
          <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-neutral-400">deployment_id</th>
          <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-neutral-400">project_id</th>
          <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-neutral-400">message_id</th>
          <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-neutral-400">actions</th>
          </tr>
        </thead>
        <tbody id="table-body" class="divide-y divide-neutral-800/50"></tbody>
      </table>
    </div>
  </div>

  <!-- Form dialog -->
  <dialog id="form-dialog" class="rounded-xl border border-neutral-700 bg-neutral-900 p-0 text-neutral-100 shadow-2xl backdrop:bg-black/60">
    <form id="entity-form" method="dialog" class="flex flex-col gap-4 p-6" style="min-width:380px">
      <h2 id="form-title" class="text-lg font-bold">New build_job</h2>
      <div class="flex flex-col gap-3">
        <input type="text" name="status" placeholder="status"
              class="rounded-lg border border-neutral-700 bg-neutral-800 px-3 py-2 text-sm text-neutral-100 placeholder:text-neutral-500 focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" required />
        <input type="text" name="prompt_summary" placeholder="prompt_summary"
              class="rounded-lg border border-neutral-700 bg-neutral-800 px-3 py-2 text-sm text-neutral-100 placeholder:text-neutral-500 focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" required />
        <input type="text" name="model" placeholder="model"
              class="rounded-lg border border-neutral-700 bg-neutral-800 px-3 py-2 text-sm text-neutral-100 placeholder:text-neutral-500 focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" required />
        <input type="number" name="tokens_used" placeholder="tokens_used" step="1"
              class="rounded-lg border border-neutral-700 bg-neutral-800 px-3 py-2 text-sm text-neutral-100 placeholder:text-neutral-500 focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" required />
        <input type="text" name="error_message" placeholder="error_message"
              class="rounded-lg border border-neutral-700 bg-neutral-800 px-3 py-2 text-sm text-neutral-100 placeholder:text-neutral-500 focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" required />
        <input type="number" name="duration_ms" placeholder="duration_ms" step="1"
              class="rounded-lg border border-neutral-700 bg-neutral-800 px-3 py-2 text-sm text-neutral-100 placeholder:text-neutral-500 focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" required />
        <textarea name="logs" placeholder="logs" rows="2"
              class="rounded-lg border border-neutral-700 bg-neutral-800 px-3 py-2 text-sm text-neutral-100 placeholder:text-neutral-500 focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" required></textarea>
        <input type="text" name="deployment_id" placeholder="deployment_id"
              class="rounded-lg border border-neutral-700 bg-neutral-800 px-3 py-2 text-sm text-neutral-100 placeholder:text-neutral-500 focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" />
        <input type="text" name="project_id" placeholder="project_id (UUID)"
              pattern="[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}"
              class="rounded-lg border border-neutral-700 bg-neutral-800 px-3 py-2 text-sm text-neutral-100 placeholder:text-neutral-500 focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" required />
        <input type="text" name="message_id" placeholder="message_id (UUID)"
              pattern="[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}"
              class="rounded-lg border border-neutral-700 bg-neutral-800 px-3 py-2 text-sm text-neutral-100 placeholder:text-neutral-500 focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" required />
      </div>
      <div class="flex justify-end gap-3 pt-2">
        <button type="button" id="cancel-btn" class="rounded-lg border border-neutral-700 px-4 py-2 text-sm transition hover:bg-neutral-800">Cancel</button>
        <button type="submit" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold transition hover:bg-indigo-500">Save</button>
      </div>
    </form>
  </dialog>

  <!-- Relation panel -->
  <dialog id="rel-dialog" class="rounded-xl border border-neutral-700 bg-neutral-900 p-6 text-neutral-100 shadow-2xl backdrop:bg-black/60" style="min-width:400px;max-height:80vh">
    <div class="flex items-center justify-between mb-4">
      <h2 id="rel-title" class="text-lg font-bold"></h2>
      <button onclick="document.getElementById('rel-dialog').close()" class="text-neutral-500 hover:text-neutral-300">&times;</button>
    </div>
    <pre id="rel-body" class="overflow-auto text-xs text-neutral-300 bg-neutral-800 rounded-lg p-4 max-h-96"></pre>
  </dialog>

  <script>
    const API = '/api/build_jobs';
    const dialog = document.getElementById('form-dialog');
    const form = document.getElementById('entity-form');
    const relDialog = document.getElementById('rel-dialog');
    let editingId = null;

    function renderRow(r) {
      return `<tr class="transition hover:bg-neutral-900/30">` +
        `<td class="px-4 py-3 font-mono text-xs text-neutral-500">${r.id.substring(0,8)}...</td>`+
        `<td class="px-4 py-3 text-sm text-neutral-300">${r.status??'—'}</td>`+
        `<td class="px-4 py-3 text-sm text-neutral-300">${r.prompt_summary??'—'}</td>`+
        `<td class="px-4 py-3 text-sm text-neutral-300">${r.model??'—'}</td>`+
        `<td class="px-4 py-3 text-sm text-neutral-300">${r.tokens_used??'—'}</td>`+
        `<td class="px-4 py-3 text-sm text-neutral-300">${r.error_message??'—'}</td>`+
        `<td class="px-4 py-3 text-sm text-neutral-300">${r.duration_ms??'—'}</td>`+
        `<td class="px-4 py-3 text-sm text-neutral-300">${r.logs??'—'}</td>`+
        `<td class="px-4 py-3 text-sm text-neutral-300">${r.deployment_id??'—'}</td>`+
        `<td class="px-4 py-3 font-mono text-xs"><a href="/admin/projects" class="text-indigo-400 hover:underline">${r.project_id?r.project_id.substring(0,8)+'...':'—'}</a></td>`+
        `<td class="px-4 py-3 font-mono text-xs"><a href="/admin/messages" class="text-indigo-400 hover:underline">${r.message_id?r.message_id.substring(0,8)+'...':'—'}</a></td>` +
        `<td class="px-4 py-3 text-sm flex gap-3">
          <button onclick="editItem('${r.id}')" class="text-indigo-400 hover:underline">edit</button>
          <button onclick="deleteItem('${r.id}')" class="text-red-400 hover:underline">del</button>
          <button onclick="showRelation('${r.id}','artifacts')" class="text-indigo-400 hover:underline">artifacts</button> <button onclick="showRelation('${r.id}','deployments')" class="text-indigo-400 hover:underline">deployments</button>
        </td></tr>`;
    }

    async function loadData() {
      const res = await fetch(API);
      const items = await res.json();
      document.getElementById('table-body').innerHTML = items.map(renderRow).join('');
    }

    document.getElementById('create-btn').addEventListener('click', () => {
      editingId = null;
      form.reset();
      document.getElementById('form-title').textContent = 'New build_job';
      dialog.showModal();
    });

    document.getElementById('cancel-btn').addEventListener('click', () => dialog.close());

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const body = {
        status: form.elements['status'].value,
        prompt_summary: form.elements['prompt_summary'].value,
        model: form.elements['model'].value,
        tokens_used: form.elements['tokens_used'].value ? Number(form.elements['tokens_used'].value) : null,
        error_message: form.elements['error_message'].value,
        duration_ms: form.elements['duration_ms'].value ? Number(form.elements['duration_ms'].value) : null,
        logs: form.elements['logs'].value,
        deployment_id: form.elements['deployment_id'].value || null,
        project_id: form.elements['project_id'].value,
        message_id: form.elements['message_id'].value
      };
      const url = editingId ? `${API}/${editingId}` : API;
      const method = editingId ? 'PUT' : 'POST';
      await fetch(url, {
        method,
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
      dialog.close();
      loadData();
    });

    window.editItem = async function(id) {
      const res = await fetch(`${API}/${id}`);
      const item = await res.json();
      editingId = id;
      document.getElementById('form-title').textContent = 'Edit build_job';
      form.elements['status'].value = item.status ?? '';
      form.elements['prompt_summary'].value = item.prompt_summary ?? '';
      form.elements['model'].value = item.model ?? '';
      form.elements['tokens_used'].value = item.tokens_used ?? '';
      form.elements['error_message'].value = item.error_message ?? '';
      form.elements['duration_ms'].value = item.duration_ms ?? '';
      form.elements['logs'].value = item.logs ?? '';
      form.elements['deployment_id'].value = item.deployment_id ?? '';
      form.elements['project_id'].value = item.project_id ?? '';
      form.elements['message_id'].value = item.message_id ?? '';
      dialog.showModal();
    };

    window.deleteItem = async function(id) {
      if (!confirm('Delete this build_job?')) return;
      await fetch(`${API}/${id}`, { method: 'DELETE' });
      loadData();
    };

    window.showRelation = async function(id, rel) {
      document.getElementById('rel-title').textContent = rel + ' for ' + id.substring(0,8) + '...';
      document.getElementById('rel-body').textContent = 'Loading...';
      relDialog.showModal();
      const res = await fetch(`${API}/${id}/${rel}`);
      const data = await res.json();
      document.getElementById('rel-body').textContent = JSON.stringify(data, null, 2);
    };

    loadData();
  </script>
</Base>
