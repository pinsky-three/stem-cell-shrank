---
import Base from "../layouts/Base.astro";
---
<Base title="Forgot Password" noindex={true}>
  <div class="flex min-h-screen items-center justify-center px-4">
    <div class="w-full max-w-md space-y-8">
      <div class="text-center">
        <h1 class="text-3xl font-bold tracking-tight">Forgot password</h1>
        <p class="mt-2 text-sm text-neutral-400">Enter your email and we'll send a reset link</p>
      </div>

      <div id="alert" class="hidden rounded-lg border px-4 py-3 text-sm"></div>

      <form id="forgot-form" class="space-y-5">
        <div>
          <label for="email" class="block text-sm font-medium text-neutral-300">Email</label>
          <input
            id="email"
            name="email"
            type="email"
            required
            autocomplete="email"
            class="mt-1 block w-full rounded-lg border border-neutral-700 bg-neutral-900 px-4 py-2.5 text-sm text-neutral-100 placeholder-neutral-500 outline-none transition focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500"
            placeholder="you@example.com"
          />
        </div>
        <button
          type="submit"
          class="w-full rounded-lg bg-indigo-600 px-4 py-2.5 text-sm font-semibold text-white transition hover:bg-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 focus:ring-offset-neutral-950 disabled:opacity-50"
        >
          Send reset link
        </button>
      </form>

      <p class="text-center text-sm text-neutral-400">
        <a href="/login" class="text-indigo-400 hover:text-indigo-300">Back to sign in</a>
      </p>
    </div>
  </div>

  <script>
    const form = document.getElementById('forgot-form');
    const alert = document.getElementById('alert');

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = document.getElementById('email').value;
      const btn = form.querySelector('button[type="submit"]');
      btn.disabled = true;

      try {
        await fetch('/auth/forgot-password', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email }),
        });

        showAlert('If an account exists for that email, a reset link has been sent.', 'success');
      } catch {
        showAlert('Network error. Please try again.', 'error');
      } finally {
        btn.disabled = false;
      }
    });

    function showAlert(msg, type) {
      alert.textContent = msg;
      alert.className = type === 'success'
        ? 'rounded-lg border border-green-800 bg-green-950 px-4 py-3 text-sm text-green-300'
        : 'rounded-lg border border-red-800 bg-red-950 px-4 py-3 text-sm text-red-300';
    }
  </script>
</Base>
