PORT=4200
DATABASE_URL=postgresql://user:password@localhost:5432/stem_cell

# ── Auth ─────────────────────────────────────────────────────────────────
APP_URL=http://localhost:4200
SESSION_TTL_HOURS=168

# ── SMTP (optional — email features disabled if SMTP_HOST is empty) ─────
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com

# ── OAuth2: GitHub (optional) ───────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── OAuth2: Google (optional) ───────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
